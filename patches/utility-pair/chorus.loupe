; UTILITY: chorus/flanger — swept fractional tap. `speed` = sweep rate, `depth` = base delay (small = flanger).
(def chorus (fn (:in :speed :depth => :out)
  (def buf (audio :seconds 0.05))
  (<- buf in)
  (def sweep (sine :rate speed))
  (<- out (mix in (tap buf :amount (add (add 200 (div depth 8)) (vca sweep 120)) :interp)))))
