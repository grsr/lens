; UTILITY: quantiser — 1V/oct quantiser with built-in S&H, transpose, and live scale select
; (knob picks a 12-bit scale mask), plus a trigger when the note changes.
; :trans is the transpose amount, named so it does not shadow the transpose op.
(def quantiser (fn (:cv :trig :trans :scale => :out :changed)
  (def note (snap (transpose (spread (hold cv trig) 60) (spread trans 24))
                  :mask (squint scale-masks scale)))
  (<- out (v-oct note))
  (<- changed (edge (ne note (z1 note))))))
